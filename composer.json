{
  "name": "lpdfio/lpdf",
  "description": "PHP adapter for lpdf — pixel-perfect, lightweight, and consistent PDF rendering",
  "type": "library",
  "license": "proprietary",
  "homepage": "https://lpdf.io",
  "authors": [
    {"name": "lpdf.io", "email": "support@lpdf.io", "homepage": "https://lpdf.io"}
  ],
  "support": {
    "source": "https://github.com/lpdfio/lpdf-php",
    "issues": "https://github.com/lpdfio/lpdf-php/issues"
  },
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11"
  },
  "autoload": {
    "psr-4": { "Lpdf\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "Lpdf\\Tests\\": "test/" }
  }
}
