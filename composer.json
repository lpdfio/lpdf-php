{
  "name": "lpdfio/lpdf",
  "description": "PHP SDK for Lpdf — PDF as Code on every platform. You describe a document as code or XML. Lpdf renders a compact, pixel-perfect PDF — identical across platforms.",
  "type": "library",
  "license": "proprietary",
  "homepage": "https://lpdf.io",
  "authors": [
    {"name": "lpdf.io", "email": "support@lpdf.io", "homepage": "https://lpdf.io"}
  ],
  "support": {
    "source": "https://github.com/lpdfio/lpdf-php",
    "issues": "https://github.com/lpdfio/lpdf-php/issues"
  },
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11"
  },
  "autoload": {
    "psr-4": { "Lpdf\\": "src/" },
    "files": ["src/constants.php"]
  },
  "autoload-dev": {
    "psr-4": { "Lpdf\\Tests\\": "test/" }
  }
}
